  "flag_rules": {
    "_comment": "Add new values here to flag more customers — no code change needed.",
    "payment_overdue":  ["overdue", "past_due", "delinquent", "unpaid", "suspended", "late", "collections"],
    "support_open":     ["open", "in progress", "pending", "awaiting", "escalated", "new", "reopened", "active"]
  },

  "source_types": {
    "_comment": "Pipeline uses filename keywords + column fingerprints to classify each incoming file.",
    "salesforce": {
      "filename_patterns": ["salesforce", "sf_", "sfdc", "crm_export", "crm"],
      "column_fingerprint": ["sf_id", "account_owner", "contact_email", "account_name", "sfid"]
    },
    "billing": {
      "filename_patterns": ["billing", "invoice", "payment", "billing_data", "accounts_receivable", "ar_"],
      "column_fingerprint": ["billing_id", "payment_status", "annual_revenue", "contract_start", "invoice"]
    },
    "support": {
      "filename_patterns": ["support", "ticket", "helpdesk", "service_desk", "case_export", "cases"],
      "column_fingerprint": ["ticket_id", "issue_type", "priority", "open_date", "case_id", "status"]
    },
    "marketing": {
      "filename_patterns": ["marketing", "mktg", "campaign", "email_list", "contacts", "marketing_data"],
      "column_fingerprint": ["mktg_id", "segment", "email_opens", "subscribed", "last_campaign_sent"]
    },
    "forecast": {
      "filename_patterns": ["forecast", "projection", "pipeline", "sales_forecast", "revenue_forecast"],
      "column_fingerprint": ["forecast_id", "q1_forecast", "q2_forecast", "total_year_forecast", "confidence"]
    }
  }
